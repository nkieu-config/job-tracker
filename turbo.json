{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^generate"],
      "outputs": ["dist/**", ".next/**"]
    },
    "generate": {
      "cache": false,
      "outputs": ["generated/**", "src/generated/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^generate"]
    },
    "lint": {},
    "test": {
      "dependsOn": ["^generate"]
    }
  }
}
