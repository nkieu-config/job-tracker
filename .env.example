# Web app environment (copy to .env)

# --- Database (Neon Postgres: DATABASE_URL is pooled, DIRECT_URL is migrate-only) ---
# The `-pooler` suffix goes on the endpoint label, not the compute label:
#   pooled: ep-xxx-pooler.c-2.<region>.aws.neon.tech   <- correct
#           ep-xxx.c-2-pooler.<region>.aws.neon.tech   <- wrong, TLS cert won't match
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.c-2.ap-southeast-1.aws.neon.tech/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.c-2.ap-southeast-1.aws.neon.tech/dbname?sslmode=require"

# --- Admin (comma-separated emails allowed to view /dashboard/ai-usage) ---
ADMIN_EMAILS=""

# --- Auth (Better Auth) ---
BETTER_AUTH_SECRET="generate-a-long-random-string"
BETTER_AUTH_URL="http://localhost:3000"

# --- OAuth (optional social sign-in) ---
# A provider's button appears only when BOTH of its vars are set, so leaving a
# pair blank simply hides it — nothing breaks. Register the OAuth app with an
# authorized callback of <BETTER_AUTH_URL>/api/auth/callback/<provider>, e.g.
# http://localhost:3000/api/auth/callback/github for local dev.
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Email (Resend: password reset + email verification) ---
# Unset in local dev/CI: sendEmail() then logs the link to the server console
# instead of sending, so both flows stay walkable without a verified domain.
RESEND_API_KEY=""
# Must be an address on a domain verified in Resend. The default sandbox sender
# (onboarding@resend.dev) only delivers to your own Resend account email.
EMAIL_FROM="Job Tracker <noreply@yourdomain.com>"

# --- File storage (Vercel Blob) ---
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"

# --- AI (Google Gemini) ---
# Server-only key used by Server Actions and Route Handlers. Never exposed to the browser.
GEMINI_API_KEY="your-gemini-api-key"

# --- Cron (Vercel) ---
# Authenticates /api/cron/* against Vercel Cron's Authorization: Bearer header.
# Unset in local dev; the route then refuses to run.
CRON_SECRET=""

# --- Optional ---
# Set to "1" to stop writing ai_usage rows (the eval harness sets this itself).
AI_USAGE_DISABLED=""
# Eval harness knobs: requests/minute pacing, total attempts per call, and the
# LLM-as-judge model (must differ from the model under test to avoid self-bias).
EVAL_RPM=""
EVAL_MAX_ATTEMPTS=""
EVAL_JUDGE_MODEL=""
# Base URL used by scripts/seed.mts.
BASE_URL=""
